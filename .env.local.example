DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=local-dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver

POSTGRES_DB=corpus_platform
POSTGRES_USER=corpus_platform
POSTGRES_PASSWORD=corpus_platform
DATABASE_URL=postgres://corpus_platform:corpus_platform@db:5432/corpus_platform

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DATA_ROOT=/app/data
USER_UPLOAD_MAX_FILE_BYTES=31457280
USER_UPLOAD_TOTAL_BYTES=31457280
TEST_UPLOAD_MAX_FILE_BYTES=2097152
TEST_UPLOAD_TOTAL_BYTES=5242880
UPLOAD_SCANNER_BACKEND=apps.corpora.scanners.DisabledUploadScanner

EXPORT_TTL_SECONDS=86400
EXPORT_MAX_ROWS=100000
EXPORT_MAX_DOWNLOADS=5
EXPORT_MAX_JOBS_PER_HOUR=10
