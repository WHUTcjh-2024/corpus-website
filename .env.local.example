DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=local-dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver

POSTGRES_DB=corpus_platform
POSTGRES_USER=corpus_platform
POSTGRES_PASSWORD=corpus_platform
DATABASE_URL=postgres://corpus_platform:corpus_platform@db:5432/corpus_platform

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

DATA_ROOT=/app/data
