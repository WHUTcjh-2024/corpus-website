DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.example
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

DATABASE_URL=postgres://user:password@postgres-host:5432/corpus_platform
REDIS_URL=redis://redis-host:6379/0
CELERY_BROKER_URL=redis://redis-host:6379/0
CELERY_RESULT_BACKEND=redis://redis-host:6379/1

DATA_ROOT=/app/data
USER_UPLOAD_MAX_FILE_BYTES=31457280
USER_UPLOAD_TOTAL_BYTES=31457280
TEST_UPLOAD_MAX_FILE_BYTES=2097152
TEST_UPLOAD_TOTAL_BYTES=5242880
UPLOAD_SCANNER_BACKEND=apps.corpora.scanners.ClamAVUploadScanner
CLAMAV_HOST=clamav-host
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=15

EXPORT_TTL_SECONDS=86400
EXPORT_MAX_ROWS=100000
EXPORT_MAX_DOWNLOADS=5
EXPORT_MAX_JOBS_PER_HOUR=10
